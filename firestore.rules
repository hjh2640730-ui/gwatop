rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 유저 데이터 ──
    match /users/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      // 이메일/전화번호 중복 확인용 (limit 1 쿼리만 허용)
      allow list: if request.auth != null && request.query.limit == 1;
      allow create: if request.auth != null && request.auth.uid == uid;
      // 본인만 수정 가능. credits/referralCredits는 서버(Cloud Function)에서만 변경
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      match /quiz_history/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /quiz_questions/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── 커뮤니티 게시글 ──
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // 작성자만 수정. commentCount/anonymousMap/anonymousCounter/likes는 CF(서비스 계정)에서만
      allow update: if request.auth != null
        && request.auth.uid == resource.data.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['commentCount', 'anonymousMap', 'anonymousCounter', 'likes']);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;

      // 댓글
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        // 본인: soft delete(deleted 필드). likes/likedBy는 서버(CF)에서만 수정
        allow update: if request.auth != null &&
          request.auth.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deleted', 'content', 'likes', 'likedBy']);
        allow delete: if false;
      }
    }

    // ── 게시글 좋아요 (Cloud Function 서비스 계정만 쓰기) ──
    match /post_likes/{likeId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── 공유 퀴즈 (누구나 읽기, 로그인 유저만 생성) ──
    match /shared_quizzes/{quizId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── 메시지함 ──
    match /global_messages/{msgId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /users/{uid}/inbox/{msgId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /users/{uid}/claimed/{msgId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── 가위바위보 게임 ──
    match /games/{gameId} {
      // 로그인 유저는 게임 목록 읽기 가능 (방 목록 표시)
      allow read: if request.auth != null;
      // 쓰기는 서버(Cloudflare Function)에서만
      allow write: if false;

      // 게임 내 채팅
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 200;
        allow update, delete: if false;
      }
    }

    // ── 나머지 모든 접근 거부 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
