rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 유저 데이터 ──
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      // 본인만 수정 가능. credits/referralCredits는 서버(Cloud Function)에서만 변경
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      match /quiz_history/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /quiz_questions/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── 커뮤니티 게시글 ──
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // 작성자: 모든 필드. 타인: commentCount/anonymousMap/anonymousCounter만 (likes는 CF만)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['commentCount', 'anonymousMap', 'anonymousCounter'])
      );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;

      // 댓글
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        // 본인: soft delete(deleted 필드). likes/likedBy는 서버(CF)에서만 수정
        allow update: if request.auth != null &&
          request.auth.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deleted', 'content', 'likes', 'likedBy']);
        allow delete: if false;
      }
    }

    // ── 게시글 좋아요 (Cloud Function 서비스 계정만 쓰기) ──
    match /post_likes/{likeId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ── 나머지 모든 접근 거부 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
